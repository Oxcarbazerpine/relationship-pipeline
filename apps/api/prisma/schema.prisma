generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Stage {
  INTRO
  COMFORT
  FLIRT
  UPGRADE
  COOLING
  ENDED
}

enum InteractionFrequency {
  HIGH
  MEDIUM
  LOW
  NONE
}

enum InitiativeDirection {
  SELF
  OTHER
  BALANCED
}

enum EmotionQuality {
  NEUTRAL
  POSITIVE
  VOLATILE
  DRAINING
}

enum InvestmentBalance {
  SELF_MORE
  BALANCED
  OTHER_MORE
}

enum OfflineStatus {
  NEVER
  ONCE
  MULTIPLE
}

enum NextAction {
  KEEP_CHAT
  LIGHT_UPGRADE
  CLEAR_INVITE
  SLOW_DOWN
  OBSERVE
  END
}

enum UpgradeSignal {
  CARE
  INVITE
  TIME_GIVE
  BODY_LANGUAGE
  EMOTIONAL_DEPENDENCE
}

enum PriorityAdvice {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum AdvisorKind {
  RULES
  AI
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  displayName    String?
  locale         String   @default("zh")
  trialEndsAt    DateTime
  subscriptionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  connections    Connection[]
  channels       Channel[]
}

model Channel {
  id          String       @id @default(cuid())
  userId      String
  name        String
  color       String       @default("blueLight2")
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections Connection[]

  @@unique([userId, name])
}

model Connection {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  stage              Stage
  lastInteractionAt  DateTime?
  interactionFreq    InteractionFrequency
  initiative         InitiativeDirection
  emotionQuality     EmotionQuality
  investmentBalance  InvestmentBalance
  offlineStatus      OfflineStatus
  upgradeSignals     UpgradeSignal[]
  suggestedAction    NextAction
  suggestedReason    String
  overrideAction     NextAction?
  overrideReason     String?
  actionDueAt        DateTime?
  notes              String?
  priorityScore      Int                 @default(0)
  priorityAdvice     PriorityAdvice      @default(UNKNOWN)
  advisor            AdvisorKind         @default(RULES)
  advisorReason      String?
  channelId          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
}
